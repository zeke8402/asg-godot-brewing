[gd_scene format=3 uid="uid://dwscfulclkjve"]

[sub_resource type="GDScript" id="GDScript_x1kum"]
script/source = "extends Node3D

'''
func _ready() -> void:
	_build_light()
	_build_landmarks()
	_build_test_camera()
	_build_player()
'''



func _build_light() -> void:
	var light := OmniLight3D.new()
	light.position = Vector3(0, 5, 0)
	light.omni_range = 20.0
	add_child(light)

func _build_landmarks() -> void:
	var positions = [
		Vector3(3, 0, 0),
		Vector3(-3, 0, 0),
		Vector3(0, 0, 3),
		Vector3(0, 0, -3),
		Vector3(5, 0, 5),
	]

	for pos in positions:
		var mesh_instance := MeshInstance3D.new()
		var sphere := SphereMesh.new()
		sphere.radius = 0.3
		sphere.height = 0.6
		mesh_instance.mesh = sphere

		var mat := StandardMaterial3D.new()
		mat.albedo_color = Color(0.8, 0.1, 0.1)
		mesh_instance.material_override = mat

		mesh_instance.position = pos
		add_child(mesh_instance)
		
func _build_test_camera() -> void:
	var cam := Camera3D.new()
	cam.position = Vector3(0, 15, 0)
	cam.rotation_degrees = Vector3(-90, 0, 0)
	cam.projection = Camera3D.PROJECTION_ORTHOGONAL
	cam.size = 20.0
	add_child(cam)

func _build_player() -> void:
	var player := CharacterBody3D.new()
	player.name = \"Player\"
	
	var script := load(\"res://player.gd\")
	player.set_script(script)

	var mesh_instance := MeshInstance3D.new()
	var sphere := SphereMesh.new()
	sphere.radius = 0.5
	sphere.height = 1.0
	mesh_instance.mesh = sphere
	player.add_child(mesh_instance)

	var col := CollisionShape3D.new()
	var shape := SphereShape3D.new()
	shape.radius = 0.5
	col.shape = shape
	player.add_child(col)

	var cam := Camera3D.new()
	cam.position = Vector3(0, 15, 0)
	cam.rotation_degrees = Vector3(-90, 0, 0)
	cam.projection = Camera3D.PROJECTION_ORTHOGONAL
	cam.size = 20.0
	player.add_child(cam)

	add_child(player)
"

[node name="Stage" type="Node3D" unique_id=1806928237]
script = SubResource("GDScript_x1kum")
